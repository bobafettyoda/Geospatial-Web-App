FROM node:20-alpine AS build
WORKDIR /app
ARG VITE_API_URL=/critical-habitat-api
ARG VITE_MARTIN_URL=/critical-habitat-tiles
ENV VITE_API_URL=$VITE_API_URL
ENV VITE_MARTIN_URL=$VITE_MARTIN_URL
COPY package*.json ./
RUN npm ci
COPY . .
RUN npm run build -- --base=/critical-habitat/

FROM nginx:alpine
COPY --from=build /app/dist /usr/share/nginx/html/critical-habitat
COPY nginx.prod.conf /etc/nginx/conf.d/default.conf
